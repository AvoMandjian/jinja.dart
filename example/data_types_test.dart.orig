// ignore_for_file: avoid_print

import 'dart:async';

import 'package:jinja/jinja.dart';
import 'package:jinja/src/nodes.dart';

import 'get_jinja.dart';

final jinjaScript = '''
{% import "data_types.jinja" as types %}

{% macro title_view(s) %}
    {{ s | title }}
{% endmacro %}

{% macro round_view(n) %}
    {{ n | round(2) }}
{% endmacro %}

{% macro switch_view(b) %}
    {{ "On" if b else "Off" }}
{% endmacro %}

{% macro decode_view(s) %}
    {{ s | frombase64 }}
{% endmacro %}

[
{{ types.create_dt_text("test string", title_view, ui_widget="single_line_text", property_label="Font Name", property_id="font_name")}},
{{ types.create_dt_number(1000.252, round_view, ui_widget="number_input", ge=0) }},
{{ types.create_dt_boolean(1, ui_widget="switch") }},
{{ types.create_dt_datetime("2026-10-10 10:10:10") }},
{{ types.create_dt_datetime(datetime.fromisoformat("2026-10-10 10:10:10")) }},
{{ types.create_dt_date("2026-10-10 10:10:10") }},
{{ types.create_dt_time("2026-10-10 10:10:10") }},
{{ types.create_dt_uuid(UUID("065d4098-8c9e-4ec1-8348-9a6beaf6a135")) }},
{{ types.create_dt_base64("SGVsbG8gV29ybGQ=", decode_view) }},
{{ types.create_dt_money(amount=1000, currency_id="USD", currency_symb="\$") }},
{{ types.create_dt_list([1, 2, 3], param={"macro": types.create_dt_number}) }},
{{ types.create_dt_object({"a": 1, "b": 2, "c": 3}, a={"macro": types.create_dt_number}, b={"macro": types.create_dt_text}, ui_widget="complex_object")}}
]
''';
final Map<String, dynamic> jinjaData = {};

void main() async {
  try {
    final errors = <String?>[];

    // Setup MapLoader with base templates for inheritance and inclusion
    final loader = MapLoader(
      {
        'data_types.jinja': '''
{#
Macros for creation of data type objects.

1. The type system is closed. Only predefined types and their combinations
(aggregations) are allowed.
2. The type system includes basic types (scalars) and compound types (containers).
3. Basic types include `text`, `number`, `boolean`, `datetime`, `date`, `time`, `uuid`
and other predefined scalar types (with `dt_` prefix).
4. Compound types include `list` (homogeneous sequential container) and `object`
(key-value mapping).
5. Instances of compound types (containers) can store only instances of basic types
or instances of other compound types (this means that instances of compound types
may be arbitrarily nested).
6. Every compound type should be parameterized with the type (or types) of the item
(or items) that it stores.
7. Instances of data types (both basic and compound) should be created via special
Jinja macros (data macros) and never directly (allowed exception: SELECT statement).
8. Data macro performs data validation, deserialization, type conversions,
and precondition/postcondition checks (e.g., pattern matching for string, range check
for number, etc.) along with JSON Schemas.
9. If input data doesn’t pass data validation, data macro should generate AssertionError
and template rendering should fail (this means that we’ll never pass to widget incorrect data).
10. Various representations of the same data for UI don’t constitute different data types
(for example, for UI we may need to have lowercase and uppercase text; in both cases
it should be text data type).
11. To handle UI representation of the data, every data macro accepts as parameter
a view macro which performs conversion of the stored data (`value`) into
appropriate representation for UI (`value_text`).
12. We may have different view macros for the same data type. For example, for `number`
data type we may have different macros for different decimal separators/formatting
(comma vs dot, etc.).

Supported basic types:
- dt_text
- dt_datetime
- dt_date
- dt_time
- dt_uuid
- dt_base64
- dt_number
- dt_boolean
- dt_money

Supported compound types:
- dt_list
- dt_object
#}

{#
-------------------------------------------------------------------------------
Helpers
-------------------------------------------------------------------------------
#}

{#
Raise AssertionError if value is not defined (auxiliary).
#}
{% macro _isdefined(value) %}
{% do assert(value or value is boolean or value is number, "Required value is not defined: " ~ value) %}
{% endmacro %}

{#
Raise assertion error if value is not an instance of a given type (auxiliary).
#}
{% macro _isinstance(value, type) %}
    {% if type == "text" %}
        {% do assert(value is string, "Not a `text`: " ~ value) %}
    {% elif type == "number" %}
        {% do assert(value is not boolean and value is number, "Not a `number`: " ~ value) %}
    {% elif type == "boolean" %}
        {% do assert(value is boolean, "Not a `boolean`: " ~ value) %}
    {% else %}
        {% do assert(false, "Invalid data type: " ~ type) %}
    {% endif %}
{% endmacro %}

{#
Raise AssertionError if value is not a valid identifier (auxiliary).
#}
{% macro _isident(value) %}
    {% if value is not none and value is defined %}
        {% do assert(value | match("[a-zA-Z_]+[a-zA-Z0-9_]*"), "Not a valid identifier: " ~ value) %}
    {% endif %}
{% endmacro %}

{#
Convert value into an object of a given type or raise AssertionError (auxiliary).
#}
{% macro _convert(value, type, strict) %}
    {% if strict %}
        {% do _isinstance(value, type) %}
        {{ value | tojson }}
    {% else %}
        {% if type == "text" %}
            "{{ value | string }}"
        {% elif type == "number" %}
                {{ value | float | tojson }}
        {% elif type == "boolean" %}
            {{ value | bool | tojson }}
        {% else %}
            {% do assert(false, "Invalid data type: ") %}
        {% endif %}
    {% endif %}
{% endmacro %}

{#
Deduce value based on given arguments or raise AssertionError (auxiliary).
#}
{% macro _populate(value, type, strict, optional, default) %}
    {% if value is undefined or value is none %}
        {% if default %}
            {{ _convert(default, type, strict) }}
        {% elif optional %}
            null
        {% else %}
            {% do assert(false, "Required value is undefined") %}
        {% endif %}
    {% else %}
        {{ _convert(value, type, strict) }}
    {% endif %}
{% endmacro %}

{#
Return uid (if it's not none) or generate uuid (auxiliary).
#}
{% macro _getuid(uid) %}
    {{ uid | string if uid is not none else uuid() }}
{% endmacro %}

{#
Return first defined object (auxiliary).
#}
{% macro _fallback(fst, sec) %}
    {{ fst if fst is not none and fst is defined else sec }}
{% endmacro %}

{#
-------------------------------------------------------------------------------
Views
-------------------------------------------------------------------------------
#}

{#
Return default string representation for an object.
#}
{% macro plain_view(v) %}
    {{ v }}
{% endmacro %}

{#
Return string representation for a number.
#}
{% macro number_view(n) %}
    {{ "{:,.2f}".format(n) }}
{% endmacro %}

{#
Return string representation for a boolean.
#}
{% macro boolean_view(b) %}
    {{ "On" if b else "Off" }}
{% endmacro %}

{#
Return string representation for money.
#}
{% macro money_view(v) %}
    {{ v.currency_symb }}{{ "{:,.2f}".format(v.amount) }}
{% endmacro %}

{#
Return null regardless of the input.
#}
{% macro empty_view(_) %}
{% endmacro %}


{#
-------------------------------------------------------------------------------
Basic types
-------------------------------------------------------------------------------
#}

{#
Reusable fields for data objects (auxiliary).
#}
{% macro _preamble(uid, ui_widget, property_label, property_id) %}
    {% set fields = [] %}

    {% do fields | append('"id": "' ~ _getuid(uid) ~ '"') %}

    {% if ui_widget is not none %}
        {% do _isident(ui_widget) %}
        {% do fields | append('"ui_widget": ' ~ ui_widget | tojson) %}
    {% endif %}

    {% if property_label is not none %}
        {% do fields | append('"property_label": ' ~ property_label | tojson) %}
    {% endif %}

    {% if property_id is not none %}
        {% do _isident(property_id) %}
        {% do fields | append('"property_id": ' ~ property_id | tojson) %}
    {% endif %}

    {{ fields | join(',\n        ') }}
{% endmacro %}

{#
Create a raw text (auxiliary).
Building block for text, datetime, date, time, uuid, base64.
#}
{% macro _raw_text(value, view, data_type, 
                   ui_widget=none, property_label=none, property_id=none,
                   strict=false, optional=false, default=none, uid=none,
                   min_length=none, max_length=none, pattern=none) %}
    {# variables #}
    {% set value = _populate(value, "text", strict, optional, default) | fromjson %}
    {% set length = value | length %}

    {# min length #}
    {% if min_length is not none %}
        {% do assert(length >= min_length, "Failed `min_length` check for: '" ~ value ~ "', min_length: " ~ min_length) %}
    {% endif %}

    {# max length #}
    {% if max_length is not none %}
        {% do assert(length <= max_length, "Failed `max_length` check for ': " ~ value ~ "', max_length: " ~ max_length) %}
    {% endif %}

    {# pattern #}
    {% if pattern is not none %}
        {% do assert(value | match(pattern), "Failed `pattern` check for: '" ~ value ~ "' , pattern: " ~ pattern) %}
    {% endif %}

    {# output #}
    {
        {{ _preamble(uid, ui_widget, property_label, property_id) }},
        "data_type": "{{ data_type }}",
        "data": {
            "value": {{ value | tojson }},
            "value_text": {{ view(value) | tojson }}
        }
    }
{% endmacro %}

{#
Create a text.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
	min_length: Min length of string.
	max_length: Max length of string.
	pattern: Regex that should be used for data validation.
#}
{% macro create_dt_text(value, view=plain_view,
                        ui_widget=none, property_label=none, property_id=none,
                        strict=false, optional=false, default=none, uid=none,
                        min_length=none, max_length=none, pattern=none) %}
    {{ _raw_text(value, view, "dt_text",
                  ui_widget, property_label, property_id,
                  strict, optional, default, uid,
                  min_length, max_length, pattern) }}
{% endmacro %}


{#
Create a datetime.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
#}
{% macro create_dt_datetime(value, view=plain_view,
                            ui_widget=none, property_label=none, property_id=none,
                            strict=false, optional=false, default=none, uid=none) %}
    {# variables #}
    {% set value = _populate(value, "text", strict, optional, default) | fromjson %}

    {# data #}
    {{ _raw_text(value[:19], view, "dt_datetime",
                  ui_widget, property_label, property_id,
                  strict, optional, default, uid,
                  min_length=none, max_length=none,
                  pattern="^d{4}-d{2}-d{2} d{2}:d{2}:d{2}\$") }}
{% endmacro %}

{#
Create a date.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
#}
{% macro create_dt_date(value, view=plain_view,
                        ui_widget=none, property_label=none, property_id=none,
                        strict=false, optional=false, default=none, uid=none) %}
    {# variables #}
    {% set value = _populate(value, "text", strict, optional, default) | fromjson %}

    {# data #}
    {% if value[:19] | match("^d{4}-d{2}-d{2} d{2}:d{2}:d{2}\$") %}
        {{ _raw_text(value[:10], view, "dt_date",
                      ui_widget, property_label, property_id,
                      strict, optional, default, uid,
                      min_length=none, max_length=none, pattern=none) }}
    {% else %}
        {{ _raw_text(value, view, "dt_date",
                      ui_widget, property_label, property_id,
                      strict, optional, default, uid,
                      min_length=none, max_length=none,
                      pattern="^d{4}-d{2}-d{2}\$") }}
    {% endif %}
{% endmacro %}

{#
Create a time.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
#}
{% macro create_dt_time(value, view=plain_view,
                     ui_widget=none, property_label=none, property_id=none,
                     strict=false, optional=false, default=none, uid=none) %}
    {# variables #}
    {% set value = _populate(value, "text", strict, optional, default) | fromjson %}

    {# data #}
    {% if value[:19] | match("^d{4}-d{2}-d{2} d{2}:d{2}:d{2}\$") %}
        {{ _raw_text(value[11:19], view, "dt_time",
                      ui_widget, property_label, property_id,
                      strict, optional, default, uid,
                      min_length=none, max_length=none, pattern=none) }}
    {% else %}
        {{ _raw_text(value, view, "dt_time",
                      ui_widget, property_label, property_id,
                      strict, optional, default, uid,
                      min_length=none, max_length=none,
                      pattern="^d{2}:d{2}:d{2}\$") }}
    {% endif %}
{% endmacro %}

{#
Create a uuid data object.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
#}
{% macro create_dt_uuid(value, view=plain_view,
                        ui_widget=none, property_label=none, property_id=none,
                        strict=false, optional=false, default=none, uid=none) %}
    {{ _raw_text(value, view, "dt_uuid",
                  ui_widget, property_label, property_id,
                  strict, optional, default, uid,
                  min_length=none, max_length=none,
                  pattern="^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\$") }}
{% endmacro %}

{#
Create a base64 data object.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
	min_length: Min length of decoded string.
	max_length: Max length of decoded string.
#}
{% macro create_dt_base64(value, view=empty_view,
                          ui_widget=none, property_label=none, property_id=none,
                          strict=false, optional=false, default=none, uid=none,
                          min_length=none, max_length=none) %}
    {{ _raw_text(value, view, "dt_base64", ui_widget, property_label, property_id,
                  strict, optional, default, uid,
                  min_length, max_length,
                  pattern="^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?\$") }}
{% endmacro %}

{#
Create a number data object.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
    gt: Greater than check.
    ge: Greater or equal check.
    lt: Less than check.
    le: Less or equal check.
    multiple_of: Multiple of check.
    max_digits: Max number of digits (including decimal part).
    decimal_places: Max number of decimal places.
    allow_inf_nan: If true, allow inf, -inf, and NaN for floats.
#}
{% macro create_dt_number(value, view=number_view,
                          ui_widget=none, property_label=none, property_id=none,
                          strict=false, optional=false, default=none, uid=none,
                          gt=none, ge=none, lt=none, le=none, multiple_of=none,
                          max_digits=none, decimal_places=none, allow_inf_nan=False) %}
    {# variables #}
    {% set value = _populate(value, "number", strict, optional, default) | fromjson %}

    {# greater than #}
    {% if gt is not none %}
        {% do assert(value > gt, "Not `gt`: ! " ~ value ~ " > " ~ gt) %}
    {% endif %}

    {# greater or equal #}
    {% if ge is not none %}
        {% do assert(value >= ge, "Not `ge`: ! " ~ value ~ " >= " ~ ge) %}
    {% endif %}

    {# less than #}
    {% if lt is not none %}
        {% do assert(value < lt, "Not `lt`: ! " ~ value ~ " < " ~ lt) %}
    {% endif %}

    {# less or equal #}
    {% if le is not none %}
        {% do assert(value <= le, "Not `le`: ! " ~ value ~ " <= " ~ le) %}
    {% endif %}

    {# multiple_of #}
    {% if multiple_of is not none %}
        {% do assert(value % multiple_of == 0, "Not `multiple_of`: ! " ~ value ~ " % " ~ multiple_of ~ " == 0") %}
    {% endif %}

    {# max_digits #}
    {% if max_digits is not none %}
        {% set digits = (value|string)|replace('.', '')|replace('-', '')|length %}
        {% do assert(digits <= max_digits, "Invalid `max_digits`: " ~ value) %}
    {% endif %}

    {# decimal_places #}
    {% if decimal_places is not none %}
        {% set parts = (value | string).split('.') %}
        {% if parts | length > 1 %}
            {% set decimals = parts[1] | length %}
        {% else %}
            {% set decimals = 0 %}
        {% endif %}
        {% do assert(decimals <= decimal_places, "Invalid `decimal_places`: " ~ value) %}
    {% endif %}

    {# inf/nan #}
    {% if not allow_inf_nan %}
        {% do assert(value == value, "NaN is not allowed: " ~ value) %}
    {% endif %}

    {# output #}
    {
        {{  _preamble(uid, ui_widget, property_label, property_id) }},
        "data_type": "dt_number",
        "data": {
            "value": {{ value | tojson }},
            "value_text": {{ view(value) | tojson }}
        }
    }
{% endmacro %}

{#
Create a boolean.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
#}
{% macro create_dt_boolean(value, view=boolean_view,
                           ui_widget=none, property_label=none, property_id=none,
                           strict=false, optional=false, default=none, uid=none) %}
    {# vars #}
    {% set value = _populate(value, "boolean", strict, optional, default) | fromjson %}

    {# output #}
    {
        {{  _preamble(uid, ui_widget, property_label, property_id) }},
        "data_type": "dt_boolean",
        "data": {
            "value": {{ value | tojson }},
            "value_text": {{ view(value) | tojson }}
        }
    }
{% endmacro %}

{#
Create a money.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
#}
{% macro create_dt_money(amount, currency_id, currency_symb, convert_rate=None,
                         view=money_view, uid=none, ui_widget=none, property_label=none,
                         property_id=none) %}
    {# vars #}
    {% set amount = _populate(amount, "number", strict=false, optional=false, default=none) | fromjson %}
    {% set currency_id = _populate(currency_id, "text", strict=false, optional=false, default=none) | fromjson %}
    {% set currency_symb = _populate(currency_symb, "text", strict=false, optional=false, default=none) | fromjson %}
    {% set convert_rate = _populate(convert_rate, "number", strict=false, optional=true) | fromjson %}
    {% set value = {
        "amount": amount,
        "currency_id": currency_id,
        "currency_symb": currency_symb,
        "convert_rate": convert_rate
    } %}

    {# output #}
    {
        {{  _preamble(uid, ui_widget, property_label, property_id) }},
        "data_type": "dt_money",
        "data": {
            "value": {{ value | tojson }},
            "value_text": {{ view(value) | tojson }}
        }
    }
{% endmacro %}

{#
-------------------------------------------------------------------------------
Compound types
-------------------------------------------------------------------------------
#}

{#
Create a list data by iterating over a value (auxiliary).
#}
{% macro _list_data(value, param) %}
    {# vars #}
    {% set func = param.macro %}
    {% do param.pop("macro") %}

    {# output #}
    [
    {% for item in value %}
        {{ func(item, param) }}{% if not loop.last %},{% endif %}
    {% endfor %}
    ]
{% endmacro %}

{#
Create a list.

Args:
    value: Iterable with input data.
    param: Dictionary describing storing type.
    data_type: List data type.
    ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	uid: Unique identifier for data object.
#}
{% macro create_dt_list(value, param, data_type=none, view=empty_view,
                        ui_widget=none, property_label=none, property_id=none,
                        uid=none) %}
    {# vars #}
    {% set data = _list_data(value, param) %}

    {# output #}
    {
        {{  _preamble(uid, ui_widget, property_label, property_id) }},
        "data_type": "{{ _fallback(data_type, "dt_list") }}",
        "data": {
            "value": {{ data }},
            "value_text": {{ view(data) | tojson }}
        }
    }
{% endmacro %}

{#
Create map data by iterating over kwargs (auxiliary).
#}
{% macro _object_data(value) %}
    {
    {% for k, v in kwargs.items() %}
        {% set func = v.macro %}
        {% do v.pop("macro") %}
        {% do _isident(k) %}
        "{{ k }}": {{ func(value[k], v) }}{% if not loop.last %},{% endif %}
    {% endfor %}
    }
{% endmacro %}

{#
Create a map.

Args:
    value: Mapping with input data.
    data_type: Map subtype.
    ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	uid: Unique identifier for data object.
	kwargs: Field description.
#}
{% macro create_dt_object(value, data_type=none, view=empty_view,
                          ui_widget=none, property_label=none, property_id=none,
                          uid=none) %}
    {# vars #}
    {% set data = _object_data(value, kwargs) %}

    {# output #}
    {
        {{  _preamble(uid, ui_widget, property_label, property_id) }},
        "data_type": "{{ _fallback(data_type, "dt_object") }}",
        "data": {
            "value": {{ data }},
            "value_text": {{ view(data) | tojson }}
        }
    }
{% endmacro %}

''',
      },
      globalJinjaData: jinjaData,
    );

    final env = GetJinja.environment(
      MockBuildContext(),
      loader,
      enableJinjaDebugLogging: true,
      valueListenableJinjaError: (error) {
        print('Jinja Error: $error');
        errors.add(error);
      },
      callbackToParentProject: ({required payload}) async {
        await Future<void>.delayed(const Duration(seconds: 2));
        return {
          'workflows': ['register_free'],
          'jinja_data': {
            'username': 'avo123123@avo.com',
            'password': 'avo@avo.com',
            'email': 'avo123123@avo.com',
            'first_name': 'avo@avo.com',
            'last_name': 'avo@avo.com',
          },
          'workflow_continue': null,
          'client_name': 'jinja-hq',
          'agent_name': 'main',
          'workflow_results': {
            'register_free': {
              'signup_user': {'message': 'User created successfully'},
              'workflow_log_id': '40032e5c-0706-452c-946e-87689bf2c609',
            },
          },
        };
      },
      // enableJinjaDebugLogging: true,
    );
    // example 2: real world example
    print('\n=== Example 2: Real world example ===');

    var template2 = env.fromString(jinjaScript);
    final output_ = (template2.body as TemplateNode).body as Output;
    final interps = output_.nodes.whereType<Interpolation>().toList();
    for (var i = 0; i < interps.length; i++) {
       var call = interps[i].value as Call;
       print("AST runtime interp " + i.toString() + " args: " + call.calling.arguments.map((e) => e.runtimeType).toString());
    }
    var result2 = await template2.renderAsync(
      jinjaData,
    );
    print('Result length: ${result2.length}');
    print('--------------------------------------------------------------------------------------------------------------------------------');
    print(result2);
    print('--------------------------------------------------------------------------------------------------------------------------------');
  } catch (e, stack) {
    print('\n!!! UNHANDLED EXCEPTION !!!');
    print(e);
    print(stack);
  }
}

