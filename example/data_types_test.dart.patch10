--- example/data_types_test.dart
+++ example/data_types_test.dart
@@ -772,3 +772,3 @@
     for (var i = 0; i < interps.length; i++) {
-       var call = interps[i].value as Call;
-       print("AST runtime interp " + i.toString() + " args: " + call.calling.arguments.map((e) => e.runtimeType).toString());
+       var val = interps[i].value;
