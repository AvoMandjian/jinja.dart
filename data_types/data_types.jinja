{#
Create a uuid data object.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
#}
{% macro create_dt_uuid(value, view=plain_view,
                        ui_widget=none, property_label=none, property_id=none,
                        strict=false, optional=false, default=none, uid=none) -%}
    {{- _raw_text(value, view, "dt_uuid",
                  ui_widget, property_label, property_id,
                  strict, optional, default, uid,
                  min_length=none, max_length=none,
                  pattern="^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$") -}}
{%- endmacro %}

{#
Create a base64 data object.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
	min_length: Min length of decoded string.
	max_length: Max length of decoded string.
#}
{% macro create_dt_base64(value, view=empty_view,
                          ui_widget=none, property_label=none, property_id=none,
                          strict=false, optional=false, default=none, uid=none,
                          min_length=none, max_length=none) %}
    {{- _raw_text(value, view, "dt_base64", ui_widget, property_label, property_id,
                  strict, optional, default, uid,
                  min_length, max_length,
                  pattern="^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$") -}}
{% endmacro %}

{#
Create a number data object.

Args:
    value: Raw input data.
	view: View which converts stored data into UI representation.
	ui_widget: Name of the corresponding UI widget.
	property_label: Property label for Designer.
	property_id: Property ID for Designer.
	strict: If true, prohibit auto type conversions.
	optional: If true, input data is not mandatory (can be null or undefined).
	default: Default in case of input data is null or undefined.
	uid: Unique identifier for data object.
    gt: Greater than check.
    ge: Greater or equal check.
    lt: Less than check.
    le: Less or equal check.
    multiple_of: Multiple of check.
    max_digits: Max number of digits (including decimal part).
    decimal_places: Max number of decimal places.
    allow_inf_nan: If true, allow inf, -inf, and NaN for floats.
#}
{% macro create_dt_number(value, view=number_view,
                          ui_widget=none, property_label=none, property_id=none,
                          strict=false, optional=false, default=none, uid=none,
                          gt=none, ge=none, lt=none, le=none, multiple_of=none,
                          max_digits=none, decimal_places=none, allow_inf_nan=False) %}
    {# variables #}
    {% set value = _populate(value, "number", strict, optional, default) | fromjson %}

    {# greater than #}
    {% if gt is not none %}
        {% assert value > gt, "Not `gt`: ! " ~ value ~ " > " ~ gt %}
    {% endif %}

    {# greater or equal #}
    {% if ge is not none %}
        {% assert value >= ge, "Not `ge`: ! " ~ value ~ " >= " ~ ge %}
    {% endif %}

    {# less than #}
    {% if lt is not none %}
        {% assert value < lt, "Not `lt`: ! " ~ value ~ " < " ~ lt %}
    {% endif %}

    {# less or equal #}
    {% if le is not none %}
        {% assert value <= le, "Not `le`: ! " ~ value ~ " <= " ~ le %}
    {% endif %}

    {# multiple_of #}
    {% if multiple_of is not none %}
        {% assert value % multiple_of == 0, "Not `multiple_of`: ! " ~ value ~ " % " ~ multiple_of ~ " == 0"%}
    {% endif %}

    {# max_digits #}
    {% if max_digits is not none %}
        {% set digits = (value|string)|replace('.', '')|replace('-', '')|length %}
        {% assert digits <= max_digits, "Invalid `max_digits`: " ~ value %}
    {% endif %}

    {# decimal_places #}
    {% if decimal_places is not none %}
        {% set parts = (value | string).split('.') %}
        {% if parts | length > 1 %}
            {% set decimals = parts[1] | length %}
        {% else %}
            {% set decimals = 0 %}
        {% endif %}
        {% assert decimals <= decimal_places, "Invalid `decimal_places`: " ~ value %}
    {% endif %}

    {# inf/nan #}
    {% if not allow_inf_nan %}
        {% assert value == value, "NaN is not allowed: " ~ value %}
        {% assert value != float('inf'), "Infinity is not allowed: " ~ value %}
        {% assert value != float('-inf'), "Infinity is not allowed: " ~ value %}
    {% endif %}

    {# output #}
    {
        {{  _preamble(uid, ui_widget, property_label, property_id) }},
        "data_type": "dt_number",
        "data": {
            "value": {{ value | tojson }},
            "value_text": {{ view(value) | tojson }}
        }
    }
{% endmacro %}

